generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // A URL agora é gerenciada preferencialmente pelo arquivo de config
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task Task []
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}


model Task {
  id String @id @default(uuid())
  title String
  description String
  status TaskStatus @default(TODO)
  priority TaskPriority @default(MEDIUM)
  dueDate DateTime
  createAt DateTime @default(now())
  updateAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  projectId String
}
