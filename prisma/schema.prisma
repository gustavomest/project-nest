generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // A URL agora é gerenciada preferencialmente pelo arquivo de config
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
